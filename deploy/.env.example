# Secrets contract seam — commit this file; never commit .env (actual values).
# Copy to deploy/.env and fill in real values before `make up`.
#
# Values here are placeholders only.  Change every password before any
# non-development use.

# ---------------------------------------------------------------------------
# Business database (persistence pod)
# ---------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=harness
DB_USER=harness
DB_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Temporal internal database (orchestration pod — managed by temporal-postgres)
# Never accessed directly by the harness; Temporal auto-setup reads these.
# ---------------------------------------------------------------------------
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Temporal connection (read by the harness worker at startup)
# ---------------------------------------------------------------------------
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_TASK_QUEUE=harness-main
TEMPORAL_NAMESPACE=default

# ---------------------------------------------------------------------------
# Ollama connection (read by the infer contract in Phase C)
# Phase A: present but unused by harness code.
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
